# Python bytecode and cache
__pycache__/
*.py[cod]
*$py.class

# Tool caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/

# Virtual environments
.venv/
venv/
.python-version

# Editor / IDE state
.vscode/
.idea/
.DS_Store

# Local logs
local_logs/
# slurm_logs/
# slurm-*.out
# *.log

# NSD data
nsddata/
nsddata_betas/
nsddata_stimuli/
nsddata_timeseries/

# Derived data
processed_data/*
!processed_data/**/
processed_data_*/
outputs/*
!outputs/**/
outputs_*/

# Explicit high-volume pipeline outputs
# These are regenerated by the SLURM pipeline and helper scripts.
processed_data/features/
processed_data/reconstruction_features/
outputs/shared_space/
outputs/predictions/
outputs/ablations/
outputs/visualizations/
outputs/reconstruction_benchmark*/
outputs/gt_recon_ab_compare/

# Binary data/model artifacts (global guardrail)
# Keep committed only via explicit allowlists below.
*.npy
*.npz
*.nii
*.nii.gz
*.mat
*.h5
*.hdf5
*.pkl
*.pt
*.pth
*.ckpt

# Allow small committed test fixtures (if needed)
!tests/fixtures/
!tests/fixtures/**

# Ensure JSON and CSV files are not accidentally ignored. This re-includes
# .json/.csv files even when their parent directories are listed above.
!*.json
!*.csv
!processed_data/**/*.json
!processed_data/**/*.csv
!outputs/**/*.json
!outputs/**/*.csv
!nsddata/**/*.json
!nsddata/**/*.csv

# (Keep parent directories available for recursive negations above)

# Test/coverage artifacts
.coverage
htmlcov/

# Build/package artifacts
build/
dist/
*.egg-info/

# Local tooling state
.codex-manager/
.gemini-manager/

# Local external reconstruction assets
vdvae/
versatile_diffusion/
