# Python bytecode and cache
__pycache__/
*.py[cod]
*$py.class

# Tool caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/

# Virtual environments
.venv/
venv/
.python-version

# Editor / IDE state
.vscode/
.idea/
.DS_Store

# Local logs
slurm_logs/
slurm-*.out
*.log

# NSD data
nsddata/
nsddata_betas/
nsddata_stimuli/
nsddata_timeseries/

# Derived data
processed_data/
outputs/

# Explicit high-volume pipeline outputs
# These are regenerated by the SLURM pipeline and helper scripts.
processed_data/features/
processed_data/reconstruction_features/
outputs/shared_space/
outputs/predictions/
outputs/ablations/
outputs/visualizations/
outputs/reconstruction_benchmark*/
outputs/gt_recon_ab_compare/

# Binary data/model artifacts (global guardrail)
# Keep committed only via explicit allowlists below.
*.npy
*.npz
*.nii
*.nii.gz
*.mat
*.h5
*.hdf5
*.pkl
*.pt
*.pth
*.ckpt

# Allow small committed test fixtures (if needed)
!tests/fixtures/
!tests/fixtures/**

# Test/coverage artifacts
.coverage
htmlcov/

# Build/package artifacts
build/
dist/
*.egg-info/

# Local tooling state
.codex-manager/
.gemini-manager/
